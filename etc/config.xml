<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <aibloggenerator>
            <general>
                <enable>0</enable>
                <default_model>openai/gpt-4o-mini</default_model>
                <temperature>0.7</temperature>
                <max_tokens>6000</max_tokens>
                <default_word_count>1200</default_word_count>
                <auto_publish>0</auto_publish>
            </general>
            <cron>
                <cron_enabled>0</cron_enabled>
                <cron_frequency>daily</cron_frequency>
                <topic_source>manual</topic_source>
                <primary_target_category_id>0</primary_target_category_id>
                <target_category_ids></target_category_ids>
                <tone>professional</tone>
                <author_id>1</author_id>
                <blog_category_ids></blog_category_ids>
                <skip_duplicates>1</skip_duplicates>
                <target_store_views>0</target_store_views>
            </cron>
        </aibloggenerator>
    </default>
</config>
